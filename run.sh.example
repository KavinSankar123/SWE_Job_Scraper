#!/usr/bin/env bash
# ---------------------------------------------------------------------------
# Launcher for the QUANT watcher (new-grad SWE roles + recruiting events).
#
# `setup.sh` copies this to run.sh, which is git-ignored — so your password is
# never committed, and `git pull` never overwrites it.
#
# Fill in the three values below, then run:  ./run.sh --list
# ---------------------------------------------------------------------------
cd "$(dirname "$0")" || exit 1

# 1. The Gmail account that SENDS the alerts (it owns the app password below).
export EMAIL_USER="you@gmail.com"

# 2. A Gmail APP PASSWORD — 16 characters, NOT your normal login password.
#    Create one at: https://myaccount.google.com/apppasswords
#    (turn on 2-Step Verification first). No spaces around the "=".
export EMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# 3. Where the job alerts should land (can be the same address).
export EMAIL_TO="you@gmail.com"

# Not using Gmail? Also set these (587 -> STARTTLS, 465 -> SSL):
#   export EMAIL_SMTP_HOST="smtp.yourprovider.com"
#   export EMAIL_SMTP_PORT="465"

exec .venv/bin/python quant/job_watcher.py "$@"
